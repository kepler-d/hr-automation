# PostgreSQL Database Configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secure_db_pass_123
POSTGRES_DB=n8n

# n8n General Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# Set this to your external URL if using webhooks (e.g. tunnel or domain)
WEBHOOK_URL=http://localhost:5678/

# HR Manager Configuration
HR_MANAGER_EMAIL=manager@example.com

# Ollama Settings
OLLAMA_MODEL=llama3
OLLAMA_API_URL=http://ollama:11434
